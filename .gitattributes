tools-cache/*.zip filter=lfs diff=lfs merge=lfs -text
tools-cache/*.exe filter=lfs diff=lfs merge=lfs -text

# Binary files
*.bit binary
*.bin binary

# Shell scripts (must use LF for Unix compatibility)
*.sh text eol=lf
*.bash text eol=lf

# Verilog and HDL source files (text)
*.v text eol=lf
*.xdc text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.md text eol=lf
